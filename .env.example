# ── LLM ──────────────────────────────────────────────────────────────────────
# OpenRouter gives you one key for many models (GPT-4o, Gemini, etc.)
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Primary and fallback vision models (same OpenRouter endpoint)
EXTRACTOR_MODEL=openai/gpt-4o
EXTRACTOR_FALLBACK_MODEL=google/gemini-2.0-flash-001

# mock = deterministic fixture responses (no API key needed, works offline)
# live = real calls through OpenRouter
EXTRACTOR_MODE=mock

# Optional Otto workflow engine bridge. Leave blank for deterministic Otto-core fallback.
OTTO_ENGINE_URL=http://localhost
OTTO_ENGINE_KEY=

# ── Database ─────────────────────────────────────────────────────────────────
# Docker Postgres (demo laptop):
#   DATABASE_URL=postgres://otto:otto@localhost:5432/otto
# Supabase (backup):
#   DATABASE_URL=postgres://postgres:password@db.ref.supabase.co:5432/postgres
# Default (docker compose):
DATABASE_URL=postgres://otto:otto@localhost:5432/otto

# ── WhatsApp ─────────────────────────────────────────────────────────────────
# simulated = in-app pane (works offline, always disclosed)
# sandbox   = real Twilio WhatsApp sandbox send
WHATSAPP_MODE=simulated

# Only needed for sandbox mode:
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Your test phone, joined to the Twilio sandbox
DEMO_SUPPLIER_WHATSAPP_TO=

# ── Voice ──────────────────────────────────────────────────────────────────
# Only needed for Flow C (Whisper transcription, stretch goal)
OPENAI_API_KEY=

# ── Cache ───────────────────────────────────────────────────────────────────
# LLM responses are cached by input hash. Pre-warm with `pnpm cache:warm`.
LLM_CACHE_DIR=./data/llm-cache

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000
OTTO_URL=http://localhost:3000
