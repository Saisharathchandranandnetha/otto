# ====================================================
# Otto Unified Environment Configuration
# ====================================================

# ---------------------------
# Global Settings
# ---------------------------
NODE_ENV=development
JWT_SECRET=otto_super_secret_dev_key

# ---------------------------
# Database (PostgreSQL)
# ---------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=otto
DB_PASSWORD=otto
DB_NAME=otto

# n8n specific DB vars mapping to shared PG
DB_TYPE=postgresdb
DB_POSTGRESDB_DATABASE=otto
DB_POSTGRESDB_HOST=localhost
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_USER=otto
DB_POSTGRESDB_PASSWORD=otto
DB_POSTGRESDB_SCHEMA=workflows

# Dify specific DB vars mapping to shared PG
# Handled via Docker compose environment blocks using DB_HOST, DB_PASSWORD, etc

# ---------------------------
# Cache & Queues (Redis)
# ---------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# n8n Redis (if used)
QUEUE_HEALTH_CHECK_ACTIVE=true
EXECUTIONS_MODE=regular

# Dify Redis
CELERY_BROKER_URL=redis://localhost:6379/1

# ---------------------------
# External Integrations
# ---------------------------
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ---------------------------
# Security & Auth
# ---------------------------
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=false
N8N_AUTH_EXEMPT_ENDPOINTS=

# ---------------------------
# App Ports
# ---------------------------
PORT=3000          # Otto Web
N8N_PORT=5678      # n8n Workflow Engine
DIFY_PORT=5001     # Dify AI Engine
