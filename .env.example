# ====================================================
# Otto Unified Environment Configuration
# ====================================================

# ---------------------------
# Global Settings
# ---------------------------
NODE_ENV=development
JWT_SECRET=otto_super_secret_dev_key

# ---------------------------
# Database (PostgreSQL)
# ---------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=otto
DB_PASSWORD=otto
DB_NAME=otto

# Otto Workflow Engine DB vars
DB_TYPE=postgresdb
DB_POSTGRESDB_DATABASE=otto
DB_POSTGRESDB_HOST=localhost
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_USER=otto
DB_POSTGRESDB_PASSWORD=otto
DB_POSTGRESDB_SCHEMA=workflows

# Otto AI Engine DB vars
# Handled via Docker compose environment blocks using DB_HOST, DB_PASSWORD, etc

# ---------------------------
# Cache & Queues (Redis)
# ---------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# Workflow Engine Queue
QUEUE_HEALTH_CHECK_ACTIVE=true
EXECUTIONS_MODE=regular
N8N_PERSONALIZATION_APP_NAME="Otto Workflow Studio"
N8N_PERSONALIZATION_COMPANY_NAME="Otto"
N8N_PERSONALIZATION_LOGO="https://raw.githubusercontent.com/Saisharathchandranandnetha/otto/main/logo.png"
N8N_HIDE_USAGE_PAGE=true

# AI Engine Queue
CELERY_BROKER_URL=redis://localhost:6379/1

# ---------------------------
# External Integrations
# ---------------------------
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ---------------------------
# Security & Auth
# ---------------------------
ENFORCE_SETTINGS_FILE_PERMISSIONS=false
AUTH_EXEMPT_ENDPOINTS=

# ---------------------------
# App Ports
# ---------------------------
PORT=3000          # Otto Web
OTTO_WORKFLOW_PORT=5678      # Otto Workflow Engine
OTTO_AI_PORT=5001           # Otto AI Engine
