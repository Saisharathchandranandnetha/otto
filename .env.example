# ====================================================
# Otto Unified Environment Configuration
# ====================================================

# ---------------------------
# Global Settings
# ---------------------------
NODE_ENV=development
JWT_SECRET=otto_super_secret_dev_key

# ---------------------------
# Database (PostgreSQL)
# ---------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=otto
DB_PASSWORD=otto
DB_NAME=otto

# Otto Workflow Engine DB vars
DB_TYPE=postgresdb
DB_POSTGRESDB_DATABASE=otto
DB_POSTGRESDB_HOST=localhost
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_USER=otto
DB_POSTGRESDB_PASSWORD=otto
DB_POSTGRESDB_SCHEMA=workflows

# Otto AI Engine DB vars
# Handled via Docker compose environment blocks using DB_HOST, DB_PASSWORD, etc

# ---------------------------
# Cache & Queues (Redis)
# ---------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# Workflow Engine Queue
QUEUE_HEALTH_CHECK_ACTIVE=true
EXECUTIONS_MODE=regular
N8N_PERSONALIZATION_APP_NAME="Otto Workflow Studio"
N8N_PERSONALIZATION_COMPANY_NAME="Otto"
N8N_PERSONALIZATION_LOGO="https://raw.githubusercontent.com/Saisharathchandranandnetha/otto/main/logo.png"
N8N_HIDE_USAGE_PAGE=true

# AI Engine Queue
CELERY_BROKER_URL=redis://localhost:6379/1

# ---------------------------
# External Integrations
# ---------------------------
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ---------------------------
# Security & Auth
# ---------------------------
ENFORCE_SETTINGS_FILE_PERMISSIONS=false
AUTH_EXEMPT_ENDPOINTS=

# ---------------------------
# App Ports
# ---------------------------
PORT=3000          # Otto Web
OTTO_WORKFLOW_PORT=5678      # Otto Workflow Engine
OTTO_AI_PORT=5001           # Otto AI Engine

# ============================================
# n8n Configuration
# ============================================
N8N_LICENSE_KEY=your_n8n_license_key_here
N8N_API_KEY=your_n8n_api_key_here
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_URL=https://your-ngrok-url.ngrok-free.app
N8N_WORKFLOW_ID=

# ============================================
# ngrok (for local Telegram webhook tunnel)
# ============================================
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# ============================================
# Telegram Bot
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username_here

# ============================================
# Dify AI
# ============================================
DIFY_API_KEY=your_dify_api_key_here
DIFY_API_URL=https://api.dify.ai/v1
DIFY_APP_ID=your_dify_app_id_here

# ============================================
# Database (n8n uses separate DB)
# ============================================
N8N_DB_NAME=n8n_db
