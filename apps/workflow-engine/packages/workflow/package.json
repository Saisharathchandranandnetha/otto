{
  "name": "n8n-workflow",
  "version": "2.30.0",
  "description": "Workflow base code of n8n",
  "types": "dist/esm/index.d.ts",
  "module": "dist/esm/index.js",
  "main": "dist/cjs/index.js",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./common": {
      "types": "./dist/esm/common/index.d.ts",
      "import": "./dist/esm/common/index.js",
      "require": "./dist/cjs/common/index.js"
    },
    "./expression-sandboxing": {
      "types": "./dist/esm/expression-sandboxing.d.ts",
      "import": "./dist/esm/expression-sandboxing.js",
      "require": "./dist/cjs/expression-sandboxing.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "clean": "rimraf dist .turbo",
    "dev": "pnpm watch",
    "typecheck": "tsc --noEmit",
    "build:vite": "vite build",
    "build": "tsc --build tsconfig.build.esm.json tsconfig.build.cjs.json",
    "build:unchecked": "tsc --build tsconfig.build.esm.json tsconfig.build.cjs.json --noCheck",
    "format": "biome format --write .",
    "format:check": "biome ci .",
    "lint": "eslint src --quiet",
    "lint:fix": "eslint src --fix",
    "watch": "tsc --build tsconfig.build.esm.json tsconfig.build.cjs.json --watch",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:changed": "janitor test-scoped",
    "test:dev": "vitest --watch",
    "mutate": "node ../../scripts/mutation-health/mutate.mjs --package-dir packages/workflow"
  },
  "files": [
    "dist/**/*"
  ],
  "devDependencies": {
    "@langchain/core": "*",
    "@n8n/config": "workspace:*",
    "@n8n/playwright-janitor": "workspace:*",
    "@n8n/typescript-config": "workspace:*",
    "@n8n/vitest-config": "workspace:*",
    "@stryker-mutator/core": "*",
    "@stryker-mutator/vitest-runner": "*",
    "@types/express": "*",
    "@types/jmespath": "^0.15.0",
    "@types/json-schema": "*",
    "@types/lodash": "*",
    "@types/luxon": "*",
    "@types/md5": "^2.3.5",
    "@types/ssh2": "*",
    "@types/xml2js": "*",
    "fast-check": "*",
    "typescript": "*",
    "vite": "*",
    "vitest": "*",
    "vitest-mock-extended": "*",
    "zod": "*"
  },
  "dependencies": {
    "@codemirror/autocomplete": "*",
    "@n8n/errors": "workspace:*",
    "@n8n/utils": "workspace:*",
    "@n8n/expression-runtime": "workspace:*",
    "@n8n/tournament": "workspace:*",
    "@sentry/core": "*",
    "@sentry/node": "*",
    "ast-types": "0.16.1",
    "axios": "*",
    "callsites": "*",
    "esprima-next": "5.8.4",
    "form-data": "*",
    "jmespath": "0.16.0",
    "js-base64": "*",
    "jssha": "3.3.1",
    "json-schema": "*",
    "lodash": "*",
    "luxon": "*",
    "md5": "2.3.0",
    "recast": "0.22.0",
    "ssh2": "*",
    "title-case": "3.0.3",
    "transliteration": "2.3.5",
    "uuid": "*",
    "xml2js": "*",
    "jsonrepair": "*"
  },
  "peerDependencies": {
    "zod": "*"
  },
  "license": "LicenseRef-n8n-sustainable-use"
}


