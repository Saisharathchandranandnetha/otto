    "@vue/test-utils": "*",
    "autoprefixer": "^10.4.19",
    "emojibase-data": "^17.0.0",
    "eslint-plugin-storybook": "*",
    "postcss": "^8.4.38",
    "sass": "^1.71.1",
    "storybook": "*",
    "storybook-addon-vue-mdx": "3.0.0",
    "stylelint": "*",
